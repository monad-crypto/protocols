{
    "name": "Pyth",
    "description": "The price layer of the global financial market.",
    "live": true,
    "categories": ["Infra::Oracle"],
    "addresses": {
        // Pyth is a pull-style oracle with a single on-chain endpoint per chain.
        // All sponsored push feeds below are delivered against this PriceFeed
        // contract. Consumers read a specific feed by passing its 32-byte feed
        // id to `IPyth.getPriceUnsafe(bytes32 id)` (see info.feedIds below).
        "PriceFeed": "0x2880aB155794e7179c9eE2e38200202908C17B43",
        "Entropy": "0xD458261E832415CFd3BAE5E416FdF3230ce6F134"
    },
    "info": {
        // Sponsored push feeds on Monad mainnet (sometimes branded as
        // "Pyth Lazer" / "Bolt"). Pyth pushes updates against the `PriceFeed`
        // contract above on a schedule defined by per-feed deviation and
        // heartbeat parameters. Each value here is the 32-byte Pyth feed id
        // used with `IPyth.getPriceUnsafe(bytes32 id)`.
        //
        // Canonical list: https://docs.pyth.network/price-feeds/core/push-feeds/evm
        // (Monad mainnet section). 60 feeds total.
        //
        // The validator only accepts 20-byte EVM addresses under the top-level
        // `addresses` key, so the 32-byte feed ids live here under `info`
        // (matching the precedent set by supra_oracles.jsonc, which keeps its
        // non-address pair list under `info.pairs`).
